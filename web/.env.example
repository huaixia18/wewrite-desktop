# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://wewrite:wewrite_dev@localhost:5432/wewrite"

# ─── NextAuth ─────────────────────────────────────────────────────────────
AUTH_SECRET="change-me-to-a-random-secret-in-production"
AUTH_TRUST_HOST="true"

# ─── AI Providers ──────────────────────────────────────────────────────────
# 推荐使用代理服务（如 Groq、OpenRouter、Nova 等），可大幅降低费用并提升速度
#
# 统一网关（推荐）：一个 Key + 一个代理地址，所有模型厂商共用
# AI_GATEWAY_BASE_URL="https://api.bltcy.ai"
# AI_GATEWAY_API_KEY="sk-..."
#
# 格式：填写代理服务的 base URL（OpenAI-compatible API 格式）
# 示例：
#   ANTHROPIC_BASE_URL="https://api.groq.com/openai/v1"
#   ANTHROPIC_API_KEY="gsk_..."
#
# 或直连官方（需要海外服务器）：
#   ANTHROPIC_BASE_URL="https://api.anthropic.com"
#   OPENAI_BASE_URL="https://api.openai.com"

AI_GATEWAY_BASE_URL="https://api.bltcy.ai"
AI_GATEWAY_API_KEY="sk-..."

# Anthropic (Claude) — 默认模型: claude-sonnet-4-7-20250514
ANTHROPIC_BASE_URL="https://api.groq.com/openai/v1"
ANTHROPIC_API_KEY="gsk_..."
ANTHROPIC_MODEL="claude-sonnet-4-7-20250514"

# OpenAI (GPT-4o) — 可选
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# ─── 绘图 API (封面图生成，可选) ──────────────────────────────────────────
# 支持 OpenAI DALL-E 3 或任何 OpenAI-compatible 绘图 API
IMAGE_GEN_BASE_URL="https://api.openai.com/v1"
IMAGE_GEN_API_KEY="sk-..."

# ─── WeChat OAuth (可选) ──────────────────────────────────────────────────
# 在微信开放平台 https://open.weixin.qq.com 创建应用后获取
WECHAT_APP_ID="wx..."
WECHAT_APP_SECRET="..."

# ─── 微信公众号草稿箱发布 (可选) ──────────────────────────────────────────
# 在微信公众号后台 https://mp.weixin.qq.com 获取
WECHAT_MP_APPID="wx..."
WECHAT_MP_APPSECRET="..."

# ─── Stripe 订阅支付 (可选) ────────────────────────────────────────────────
# 在 https://dashboard.stripe.com 创建产品和价格后获取
# 支持支付宝 / 微信支付 / 信用卡
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs（在 Stripe Dashboard 创建产品后获取）
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."

# 站点根 URL（用于 Stripe 回调）
NEXT_PUBLIC_BASE_URL="https://your-domain.com"
