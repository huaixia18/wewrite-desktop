# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://wewrite:wewrite_dev@localhost:5432/wewrite"

# ─── NextAuth ─────────────────────────────────────────────────────────────
AUTH_SECRET="change-me-to-a-random-secret-in-production"
AUTH_TRUST_HOST="true"

# ─── AI Providers ─────────────────────────────────────────────────────────
# Anthropic (Claude) — 推荐
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (GPT-4) — 可选
OPENAI_API_KEY="sk-..."

# ─── WeChat OAuth (可选) ──────────────────────────────────────────────────
# 在微信开放平台 https://open.weixin.qq.com 创建应用后获取
WECHAT_APP_ID="wx..."
WECHAT_APP_SECRET="..."

# ─── 微信公众号草稿箱发布 (可选) ──────────────────────────────────────────
# 在微信公众号后台 https://mp.weixin.qq.com 获取
WECHAT_MP_APPID="wx..."
WECHAT_MP_APPSECRET="..."
